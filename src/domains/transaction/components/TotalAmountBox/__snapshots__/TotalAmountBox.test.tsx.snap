// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TotalAmountBox > should render with amount of 0.1 and fee of 0.01 1`] = `
<DocumentFragment>
  <div
    data-testid="DetailWrapper"
  >
    <div
      class="border-l-2 border-x-theme-primary-400 bg-theme-secondary-100 px-3 py-2 dim:border-x-theme-dim-navy-400 dim:bg-theme-dim-950 dark:bg-black sm:border-none sm:bg-transparent sm:p-0 dim:sm:bg-transparent dark:sm:bg-transparent"
      data-testid="DetailLabel"
    >
      <div
        class="no-ligatures min-w-24 font-semibold text-theme-secondary-700 dim:text-theme-dim-200 dark:text-theme-secondary-500 text-sm leading-[17px] sm:text-base sm:leading-5"
        data-testid="DetailLabelText"
      >
        Transaction Summary
      </div>
    </div>
    <div
      class="overflow-hidden border-theme-secondary-300 dim:border-theme-dim-700 dark:border-theme-dark-700 sm:border mt-0 sm:mt-2 rounded-xl"
    >
      <div
        class="sm:in-[.condensed]:py-4 w-full break-words p-3 sm:px-6 sm:py-5"
      >
        <div
          class="flex flex-col gap-3"
        >
          <div
            class="flex items-center justify-between space-x-2 sm:justify-start sm:space-x-0"
            data-testid="AmountSection"
          >
            <div
              class="no-ligatures shrink-0 text-sm font-semibold leading-[17px] text-theme-secondary-700 dim:text-theme-dim-200 dark:text-theme-secondary-500 sm:text-base sm:leading-5 w-auto sm:min-w-36"
              data-testid="DetailTitle"
            >
              Amount
            </div>
            <div
              class="flex flex-row items-center gap-2"
            >
              <span
                class="whitespace-nowrap font-semibold"
                data-testid="Amount"
              >
                0.10 ARK
              </span>
            </div>
          </div>
          <div
            class="flex items-center justify-between space-x-2 sm:justify-start sm:space-x-0"
          >
            <div
              class="no-ligatures shrink-0 text-sm font-semibold leading-[17px] text-theme-secondary-700 dim:text-theme-dim-200 dark:text-theme-secondary-500 sm:text-base sm:leading-5 w-auto sm:min-w-36"
              data-testid="DetailTitle"
            >
              Fee
            </div>
            <div
              class="flex flex-row items-center gap-2"
            >
              <span
                class="whitespace-nowrap font-semibold"
                data-testid="Amount"
              >
                0.01 ARK
              </span>
            </div>
          </div>
          <div
            class="flex items-center justify-between space-x-2 sm:justify-start sm:space-x-0"
          >
            <div
              class="no-ligatures shrink-0 text-sm font-semibold leading-[17px] text-theme-secondary-700 dim:text-theme-dim-200 dark:text-theme-secondary-500 sm:text-base sm:leading-5 w-auto sm:min-w-36"
              data-testid="DetailTitle"
            >
              Total
            </div>
            <div
              class="flex flex-row items-center gap-2"
            >
              <span
                class="whitespace-nowrap font-semibold"
                data-testid="Amount"
              >
                0.11 ARK
              </span>
            </div>
          </div>
        </div>
      </div>
      <div
        class="flex w-full flex-col bg-theme-secondary-300 px-6 py-3 dark:bg-theme-secondary-800"
      >
        <div
          class="flex items-center justify-between space-x-2 sm:justify-start sm:space-x-0"
        >
          <div
            class="no-ligatures shrink-0 text-sm font-semibold leading-[17px] text-theme-secondary-700 dim:text-theme-dim-200 dark:text-theme-secondary-500 leading-4! w-auto sm:min-w-36 sm:text-sm"
            data-testid="DetailTitle"
          >
            Confirmation Time
          </div>
          <div
            class="leading-4! flex flex-row items-center gap-2 lowercase sm:text-sm"
          >
            ~10s
          </div>
        </div>
      </div>
    </div>
  </div>
</DocumentFragment>
`;

