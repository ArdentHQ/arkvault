                  class="mr-2 whitespace-nowrap font-semibold leading-5 text-theme-secondary-700 dim:text-theme-dim-200 dark:text-theme-dark-200"
                >
                  Hide Dust
                </div>
                <label
                  class="flex items-center cursor-pointer h-4"
                >
                  <input
                    class="toggle-input sr-only"
                    data-testid="HideDustTokens"
                    name="hideDust"
                    type="checkbox"
                  />
                  <div
                    class="toggle-handle relative inline-flex h-[5px] rounded-full bg-theme-primary-100 dim:bg-theme-dim-700 dark:bg-theme-secondary-800 w-[30px]"
                  >
                    <span
                      class="absolute top-1/2 -translate-y-1/2 rounded-full transition-all duration-200 ease-in-out bg-theme-secondary-400 dim:bg-theme-dim-500 dark:bg-theme-secondary-600 h-4 w-4 handle-inner"
