exports[`TokensTable > should not render in xl 1`] = `
<DocumentFragment>
  <div
    class="w-full last:pb-8 mt-4 py-0 pt-0 first:pt-1 md:mt-0"
  >
    <div
      class="mx-auto px-6 md:px-10 lg:container lg:pb-28 md:pb-18 sm:pb-16 pb-18"
