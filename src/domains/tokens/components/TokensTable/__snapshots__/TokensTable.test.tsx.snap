                >
                  Hide Dust
                </div>
                <label
                  class="flex items-center cursor-pointer h-4"
                >
                  <input
                    class="toggle-input sr-only"
                    data-testid="HideDustTokens"
                    name="hideDust"
                    type="checkbox"
                  />
                  <div
                    class="toggle-handle bg-theme-primary-100 dark:bg-theme-secondary-800 dim:bg-theme-dim-700 relative inline-flex h-[5px] rounded-full w-[30px]"
                  >
                    <span
                      class="absolute top-1/2 -translate-y-1/2 rounded-full transition-all duration-200 ease-in-out bg-theme-secondary-400 dark:bg-theme-secondary-600 dim:bg-theme-dim-500 h-4 w-4 handle-inner"
                    />
