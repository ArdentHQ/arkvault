                class="h-5 relative mx-2 border-l border-t-0 border-solid align-middle hidden border-theme-secondary-300 dim:border-theme-dim-700 dark:border-theme-secondary-800"
              />
              <button
                class="space-x-3 relative items-center inline-flex justify-center font-semibold text-center transition-all duration-100 ease-linear outline-hidden rounded cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-theme-primary-400 disabled:cursor-not-allowed border-none group px-2 py-1 text-sm text-theme-primary-600 hover:bg-theme-primary-200 hover:text-theme-primary-700 dim:bg-transparent dim:text-theme-dim-200 dim-hover:bg-theme-dim-700 dim-hover:text-theme-dim-50 dark:bg-transparent dark:text-theme-dark-50 dark:hover:bg-theme-dark-700 dark:hover:text-theme-dark-50"
                data-testid="TokensTable_Manage"
                type="button"
