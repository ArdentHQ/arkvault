{
	"name": "arkvault",
	"version": "1.18.0",
	"engines": {
		"node": "22.x"
	},
	"private": true,
	"description": "ARK Vault",
	"homepage": "./",
	"bugs": {
		"url": "https://github.com/ArdentHQ/arkvault/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ArdentHQ/arkvault.git"
	},
	"license": "CC BY-NC-ND 4.0",
	"author": "ARK Vault <info@arkvault.io>",
	"contributors": [
		"Alex Barnsley <alex@ark.io>",
		"Brian Faust <brian@ark.io>",
		"ItsANameToo <michel@ark.io>",
		"Lúcio Rubens <lucio@ark.io>"
	],
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"build:e2e": "REACT_APP_IS_E2E=1 vite build",
		"build:analyze": "ANALYZE_BUNDLE=1 vite build",
		"format": "pnpm lint && pnpm prettier",
		"lint": "eslint '*/**/*.{js,ts,tsx}' --quiet --fix",
		"prettier": "prettier --write \"./*.{ts,tsx,js,json,md}\" \"./**/*.{ts,tsx,js,json,md}\"",
		"qa": "pnpm install && pnpm build && pnpm serve",
		"serve": "vite preview --port 5001 --host=0.0.0.0",
		"serve:https": "vite preview --port 5001 --https",
		"test": "LC_ALL=en_US.UTF-8 vitest --update",
		"test:coverage": "LC_ALL=en_US.UTF-8 vitest run --coverage",
		"test:e2e": "E2E_HOST='http://localhost:5001' gherkin-testcafe 'chrome --disable-features=LocalNetworkAccessChecks' --config-file=.testcaferc.json",
		"test:e2e:ci": "E2E_HOST='http://localhost:5001' gherkin-testcafe --config-file=.testcaferc.json 'chrome:headless --disable-features=LocalNetworkAccessChecks' -q attemptLimit=3,successThreshold=1",
		"test:e2e:ci:firefox": "E2E_HOST='http://localhost:5001' gherkin-testcafe --config-file=.testcaferc.json firefox:headless -q attemptLimit=3,successThreshold=1",
		"test:e2e:ci:edge": "E2E_HOST='http://localhost:5001' gherkin-testcafe --config-file=.testcaferc.json edge:headless -q attemptLimit=3,successThreshold=1",
		"sdk:install-local": "node scripts/install-local-sdk.js",
		"sdk:check-updates": "npx npm-check-updates \"/^@ardenthq.*$/\" -u",
		"unused": "npx knip --config ./knip.json"
	},
	"dependencies": {
		"@ardenthq/arkvault-crypto": "^0.0.8",
		"@ardenthq/arkvault-url": "^1.2.0",
